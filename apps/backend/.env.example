# [ Binding ]
HOST=127.0.0.1  # API host
PORT=4000   # API port

# [ Configuration ]
APP_URL=http://localhost:5173
DISCORD_USER_ID=your-discord-user # Make sure you're in the same Discord Server as the bot bound to the lanyard instance.
LANYARD_URL=ws://LanyardBaseUrl # The Base URL of the Lanyard Instance (WS Protocol).
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgres://user:password@localhost:5432/znko

# [ SECURITY ]
SESSION_SECRET=change-me # openssl rand -hex 32 or crypto.randomBytes(16).toHex()
OIDC_ISSUER=https://id.example.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret