{
  "name": "@znko/backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#core/*": "./src/core/*.ts",
    "#db/*": "./src/db/*.ts",
    "#auth/*": "./src/auth/*.ts",
    "#handlers/*": "./src/handlers/*.ts",
    "#services/*": "./src/services/*.ts",
    "#controllers/*": "./src/controllers/*.ts",
    "#routes/*": "./src/routes/*.ts",
    "#middleware/*": "./src/middleware/*.ts",
    "#security/*": "./src/security/*.ts",
    "#types/*": "./src/types/*.ts",
    "#functions/*": "./src/functions/*.ts",
    "#/*": "./src/*.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc --noEmit",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "npx drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "npx drizzle-kit migrate --config=drizzle.config.ts",
    "db:push": "npx drizzle-kit push --config=drizzle.config.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.3",
    "@znko/consts": "*",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "file-type": "^21.3.4",
    "hono": "^4.12.9",
    "nanoid": "^5.1.7",
    "openid-client": "^6.8.2",
    "postgres": "^3.4.8",
    "redis": "^5.11.0",
    "slug": "^11.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@types/slug": "^5.0.9",
    "bun-types": "^1.3.12",
    "drizzle-kit": "^0.31.10",
    "typescript": "~5.9.3"
  }
}
