# Domain where app is served at 
APP_URL=http://localhost:8080

# Web server port
WEB_PORT=8080

# Postgres database connection settings
POSTGRES_USER=znko
POSTGRES_PASSWORD=znko
POSTGRES_DB=znko

# Sign cookies / sessions. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-32-byte-hex-string

# OpenID Connect provider for login (e.g. Authentik, Keycloak, Auth0).
OIDC_ISSUER=https://issuer.example.com/realms/znko
OIDC_CLIENT_ID=znko
OIDC_CLIENT_SECRET=replace-me

# Optional Discord presence integration via Lanyard.
LANYARD_URL=wss://api.lanyard.rest
DISCORD_USER_ID=

# Optional comma-separated list of trusted proxy IPv4 addresses.
TRUSTED_PROXIES=
